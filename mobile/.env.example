# Copy to .env and set your PC's LAN IP (same Wi‑Fi as the phone).
# Find it: Windows → ipconfig → IPv4 under your active adapter.
# Backend must listen on all interfaces: uvicorn app.main:app --host 0.0.0.0 --port 8000
#
# Physical Android / iOS device (required for real phone):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000
#
# Android emulator (default if unset):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000
